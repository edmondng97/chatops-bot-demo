# ── Slack (Socket Mode) ─────────────────────────────────────────────
# 1. https://api.slack.com/apps → Create New App
# 2. Socket Mode → Enable; create App-Level Token with scope connections:write → SLACK_APP_TOKEN (xapp-...)
# 3. OAuth & Permissions → Bot Token Scopes: chat:write, app_mentions:read, im:history → Install → SLACK_BOT_TOKEN (xoxb-...)
# 4. Event Subscriptions → Subscribe to bot events: app_mention, message.im
# 5. Interactivity & Shortcuts → Enable (Socket Mode needs no Request URL)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Lark (WebSocket long connection) ────────────────────────────────
# 1. https://open.larksuite.com (或 open.feishu.cn) → Create App → enable Bot capability
# 2. Permissions: im:message, im:message:send_as_bot
# 3. Events: use "long connection" mode; subscribe im.message.receive_v1; enable card interaction callback via long connection
# 4. App credentials → LARK_APP_ID (cli_...) / LARK_APP_SECRET
LARK_APP_ID=
LARK_APP_SECRET=
